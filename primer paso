import tkinter as tk
from tkinter import messagebox
import json
import os

# Archivo donde se guardan los datos
ARCHIVO = "inventario.json"

# Lista de inventario
inventario = []

# ---------------- FUNCIONES ---------------- #

def guardar_datos():
    with open(ARCHIVO, "w") as f:
        json.dump(inventario, f)

def cargar_datos():
    global inventario
    if os.path.exists(ARCHIVO):
        with open(ARCHIVO, "r") as f:
            inventario = json.load(f)
            for item in inventario:
                lista.insert(tk.END, f"{item['producto']} - ${item['precio']} - Cantidad: {item['cantidad']}")

def limpiar():
    entrada_producto.delete(0, tk.END)
    entrada_precio.delete(0, tk.END)
    entrada_cantidad.delete(0, tk.END)

def agregar():
    producto = entrada_producto.get()
    precio = entrada_precio.get()
    cantidad = entrada_cantidad.get()

    if producto == "" or precio == "" or cantidad == "":
        messagebox.showwarning("Error", "Completa todos los campos")
        return

    if not precio.isdigit() or not cantidad.isdigit():
        messagebox.showwarning("Error", "Precio y cantidad deben ser números")
        return

    item = {
        "producto": producto,
        "precio": int(precio),
        "cantidad": int(cantidad)
    }

    inventario.append(item)
    lista.insert(tk.END, f"{producto} - ${precio} - Cantidad: {cantidad}")

    guardar_datos()
    limpiar()

def eliminar():
    seleccion = lista.curselection()

    if not seleccion:
        messagebox.showwarning("Error", "Selecciona un producto")
        return

    index = seleccion[0]
    lista.delete(index)
    inventario.pop(index)

    guardar_datos()

def seleccionar_item(event):
    try:
        index = lista.curselection()[0]
        item = inventario[index]

        limpiar()
        entrada_producto.insert(0, item["producto"])
        entrada_precio.insert(0, item["precio"])
        entrada_cantidad.insert(0, item["cantidad"])
    except:
        pass

def actualizar():
    seleccion = lista.curselection()

    if not seleccion:
        messagebox.showwarning("Error", "Selecciona un producto")
        return

    producto = entrada_producto.get()
    precio = entrada_precio.get()
    cantidad = entrada_cantidad.get()

    if producto == "" or precio == "" or cantidad == "":
        messagebox.showwarning("Error", "Completa todos los campos")
        return

    if not precio.isdigit() or not cantidad.isdigit():
        messagebox.showwarning("Error", "Precio y cantidad deben ser números")
        return

    index = seleccion[0]

    inventario[index] = {
        "producto": producto,
        "precio": int(precio),
        "cantidad": int(cantidad)
    }

    lista.delete(index)
    lista.insert(index, f"{producto} - ${precio} - Cantidad: {cantidad}")

    guardar_datos()
    limpiar()

# ---------------- INTERFAZ ---------------- #

ventana = tk.Tk()
ventana.title("Sistema de Inventario PRO")
ventana.geometry("400x550")
ventana.config(bg="#2c3e50")

tk.Label(
    ventana,
    text="Sistema de Inventario",
    bg="#2c3e50",
    fg="white",
    font=("Arial", 16, "bold")
).pack(pady=10)

tk.Label(ventana, text="Producto", bg="#2c3e50", fg="white").pack()
entrada_producto = tk.Entry(ventana)
entrada_producto.pack()

tk.Label(ventana, text="Precio", bg="#2c3e50", fg="white").pack()
entrada_precio = tk.Entry(ventana)
entrada_precio.pack()

tk.Label(ventana, text="Cantidad", bg="#2c3e50", fg="white").pack()
entrada_cantidad = tk.Entry(ventana)
entrada_cantidad.pack()

# Botones
tk.Button(ventana, text="Agregar", bg="#27ae60", fg="white", width=15, command=agregar).pack(pady=5)
tk.Button(ventana, text="Actualizar", bg="#2980b9", fg="white", width=15, command=actualizar).pack(pady=5)
tk.Button(ventana, text="Eliminar", bg="#c0392b", fg="white", width=15, command=eliminar).pack(pady=5)

# Lista
lista = tk.Listbox(ventana)
lista.pack(fill=tk.BOTH, expand=True, pady=10, padx=10)

lista.bind("<<ListboxSelect>>", seleccionar_item)

# Cargar datos al iniciar
cargar_datos()

ventana.mainloop()
